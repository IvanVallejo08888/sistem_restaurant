# Contraseña del Administrador (acceso al panel Admin)
NEXT_PUBLIC_ADMIN_PASSWORD=admin123

# Nombre del negocio
NEXT_PUBLIC_BUSINESS_NAME=Heladería Antojos

# --- Backend real (Supabase / PostgreSQL) ---
# Cambia a "true" para que la app use las API Routes + Supabase en vez de LocalStorage.
NEXT_PUBLIC_USE_BACKEND=false

# Credenciales del proyecto de Supabase (Project Settings > API).
# SUPABASE_SERVICE_ROLE_KEY es secreta: solo se usa en las API Routes (servidor).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Secreto para autenticación futura
# AUTH_SECRET=
